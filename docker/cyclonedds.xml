<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
    <Domain Id="any">
        <General>
            <Interfaces>
                <NetworkInterface name="lo" priority="default" />
                <NetworkInterface name="wlp129s0f0" priority="default" />
            </Interfaces>
            <AllowMulticast>true</AllowMulticast>
            <MaxMessageSize>65500B</MaxMessageSize>
            <FragmentSize>64000B</FragmentSize>
        </General>
        <Discovery>
            <EnableTopicDiscoveryEndpoints>true</EnableTopicDiscoveryEndpoints>
            <ParticipantIndex>auto</ParticipantIndex>
            <MaxAutoParticipantIndex>50</MaxAutoParticipantIndex>
            <Peers>
                <Peer Address="127.0.0.1"/>
                <Peer Address="localhost"/>
            </Peers>
        </Discovery>
        <Internal>
            <Watermarks>
                <WhcHigh>100MB</WhcHigh>
            </Watermarks>
            <MaxSampleSize>50MB</MaxSampleSize>
            <SocketReceiveBufferSize min="10MB" max="default" />
            <SocketSendBufferSize min="5MB" max="default" />
            <DefragReliableMaxSamples>32</DefragReliableMaxSamples>
            <DeliveryQueueMaxSamples>64</DeliveryQueueMaxSamples>
        </Internal>
    </Domain>
</CycloneDDS>
